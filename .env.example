# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: Upstash Redis for conversation memory (free tier at upstash.com)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here

# Model to use (free models on OpenRouter)
# Options: meta-llama/llama-3.1-8b-instruct:free, google/gemma-2-9b-it:free, mistralai/mistral-7b-instruct:free
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Your site URL for OpenRouter analytics (optional)
OPENROUTER_SITE_URL=https://your-vercel-app.vercel.app
OPENROUTER_APP_NAME=DS-Mentor-Bot